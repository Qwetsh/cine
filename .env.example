# ============================================================
# Ciné — Variables d'environnement
# Copiez ce fichier en .env et renseignez vos clés
# ============================================================

# --- Supabase ---
# Trouvez ces valeurs dans : Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre-anon-key-publique

# --- TMDB (The Movie Database) ---
# Créez un compte sur https://www.themoviedb.org
# Puis : Settings > API > API Key (v3 auth)
VITE_TMDB_API_KEY=votre-clé-api-tmdb

# --- RAWG (couvertures de jeux vidéo) ---
# Créez un compte sur https://rawg.io/apidocs (gratuit)
VITE_RAWG_API_KEY=votre-clé-rawg
